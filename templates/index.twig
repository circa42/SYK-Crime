{% extends '_layouts/base' %}

{% block content %}
<div class="xs:mx-6 md:mx-auto sm:container my-12">
    {% set entry = craft.entries.section('home').one() %}
    {% if entry and entry.eventDetails %}
        <article class="ck-content mb-12">
            {{ entry.body | raw }}
        </article>
    {% endif %}

    {% set headline = "Books" %}
    {% if craft.entries().section('books').status('live').limit(1).exists() %}
        {% include "_includes/allbooks" %}
    {% endif %}
    </div>
{% endblock %}
